# Copy to .env and fill in. NEVER commit .env (it holds your Bedrock token).

# --- required ---
# AWS Bedrock bearer token (the only upstream credential; stays server-side).
# Get one from the AWS console (Bedrock API keys) or your org's Bedrock setup.
AWS_BEARER_TOKEN_BEDROCK=

# Strong admin password for the new-api root user (>=8 chars, alphanumeric to avoid shell-escaping issues).
ADMIN_PASSWORD=

# --- optional (sane defaults) ---
AWS_REGION=us-west-2
NEWAPI_PORT=41029         # admin UI + raw new-api API
SANITIZER_PORT=41030      # Claude Code entrypoint (strips Bedrock-incompatible beta flags)
NEWAPI_VERSION=v1.0.0-rc.15
KEY_BUDGET_USD=5          # budget for the auto-created team key

# SESSION_SECRET is auto-generated on first setup if unset.
# SESSION_SECRET=
